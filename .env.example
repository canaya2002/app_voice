# ── Client-side (Expo) ────────────────────────────────────────────────────
# Public — embedded in the bundle. NEVER put secrets here.
EXPO_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
EXPO_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Web dashboard reads these too (Vite imports them as VITE_* via prefix tweak).
# Configure in web/.env if running web separately.

# ── Server-side / Edge Functions only (NEVER ship to client) ─────────────
# Set these via `supabase secrets set` so they reach edge functions.

# AI providers
GROQ_API_KEY=gsk_...
ANTHROPIC_API_KEY=sk-ant-...

# Supabase server access
SUPABASE_SERVICE_ROLE_KEY=eyJ...

# RevenueCat (mobile billing)
# Public SDK keys — embedded in client bundle via EXPO_PUBLIC_ prefix.
EXPO_PUBLIC_REVENUECAT_API_KEY_IOS=appl_...
EXPO_PUBLIC_REVENUECAT_API_KEY_ANDROID=goog_...
# Server-side webhook secret (edge function only)
REVENUECAT_WEBHOOK_SECRET=whk_...

# Stripe (web billing)
STRIPE_SECRET_KEY=sk_test_...
STRIPE_WEBHOOK_SECRET=whsec_...
STRIPE_PRICE_PREMIUM_MONTHLY=price_...
STRIPE_PRICE_PREMIUM_YEARLY=price_...
STRIPE_PRICE_ENTERPRISE_MONTHLY=price_...
STRIPE_PRICE_ENTERPRISE_YEARLY=price_...
STRIPE_SUCCESS_URL=https://sythio.app/settings?stripe=success
STRIPE_CANCEL_URL=https://sythio.app/settings?stripe=cancel

# Slack (optional integration)
SLACK_DEFAULT_WEBHOOK_URL=

# Google Calendar (optional integration)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=https://your-project.supabase.co/functions/v1/calendar-auth?action=callback

# Apple Sign In is configured in Supabase Auth (Provider settings), no env needed.
