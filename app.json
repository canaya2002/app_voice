{
  "expo": {
    "name": "Sythio",
    "slug": "sythio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sythio",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sythio.app",
      "buildNumber": "1",
      "requireFullScreen": true,
      "usesAppleSignIn": true,
      "associatedDomains": [
        "applinks:sythio.app"
      ],
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Sythio usa el micrófono para grabar notas de voz, reuniones e ideas. El audio se procesa con IA para generar resúmenes, tareas y reportes.",
        "NSPhotoLibraryUsageDescription": "Sythio necesita acceso a tus fotos para que puedas establecer una foto de perfil personalizada.",
        "NSCameraUsageDescription": "Sythio usa la cámara para que puedas tomar una foto de perfil.",
        "NSPrivacyTracking": false,
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": [
          "audio"
        ]
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B0B0B",
        "foregroundImage": "./assets/images/icon.png"
      },
      "package": "com.sythio.app",
      "permissions": [
        "android.permission.RECORD_AUDIO",
        "android.permission.READ_EXTERNAL_STORAGE",
        "android.permission.MODIFY_AUDIO_SETTINGS"
      ],
      "edgeToEdgeEnabled": true,
      "intentFilters": [
        {
          "action": "VIEW",
          "autoVerify": true,
          "data": [
            {
              "scheme": "https",
              "host": "sythio.app"
            }
          ],
          "category": [
            "BROWSABLE",
            "DEFAULT"
          ]
        }
      ]
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-apple-authentication",
      [
        "expo-av",
        {
          "microphonePermission": "Sythio usa el micrófono para grabar tus notas de voz, reuniones e ideas. El audio se procesa con IA para generar resúmenes, tareas y más."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#0B0B0B"
        }
      ],
      [
        "expo-image-picker",
        {
          "photosPermission": "Sythio necesita acceso a tus fotos para tu foto de perfil."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "eas": {
        "projectId": "a7176742-154f-4c45-8200-8c2f6bb2dccc"
      }
    },
    "owner": "carlosanaya"
  }
}
