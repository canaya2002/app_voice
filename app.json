{
  "expo": {
    "name": "Sythio",
    "slug": "sythio",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "sythio",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.sythio.app",
      "buildNumber": "1",
      "infoPlist": {
        "NSMicrophoneUsageDescription": "Sythio usa el micrófono para grabar tus notas de voz, reuniones e ideas. El audio se procesa con IA para generar resúmenes, tareas y más.",
        "ITSAppUsesNonExemptEncryption": false,
        "UIBackgroundModes": ["audio"]
      },
      "config": {
        "usesNonExemptEncryption": false
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#0B0B0B",
        "foregroundImage": "./assets/images/icon.png"
      },
      "package": "com.sythio.app",
      "permissions": ["RECORD_AUDIO", "READ_EXTERNAL_STORAGE"],
      "edgeToEdgeEnabled": true
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-av",
        {
          "microphonePermission": "Sythio usa el micrófono para grabar tus notas de voz, reuniones e ideas. El audio se procesa con IA para generar resúmenes, tareas y más."
        }
      ],
      [
        "expo-notifications",
        {
          "color": "#0B0B0B"
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/icon.png",
          "imageWidth": 200,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    }
  }
}
